{
  "name": "gitwiki",
  "version": "0.1.0",
  "description": "A fully static, Confluence-like wiki over a GitHub repo: edit Markdown, branch as drafts, comment via GitHub Issues. Each user signs in with their own GitHub account.",
  "type": "module",
  "scripts": {
    "build": "esbuild web/main.js --bundle --outfile=public/bundle.js --format=iife --sourcemap",
    "watch": "esbuild web/main.js --bundle --outfile=public/bundle.js --format=iife --sourcemap --watch",
    "dev": "esbuild web/main.js --bundle --outfile=public/bundle.js --format=iife --sourcemap --servedir=public"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.2",
    "@supabase/supabase-js": "^2.108.1",
    "@tiptap/core": "^2.10.3",
    "@tiptap/extension-code-block": "^2.10.3",
    "@tiptap/extension-link": "^2.10.3",
    "@tiptap/extension-table": "^2.10.3",
    "@tiptap/extension-table-cell": "^2.10.3",
    "@tiptap/extension-table-header": "^2.10.3",
    "@tiptap/extension-table-row": "^2.10.3",
    "@tiptap/pm": "^2.10.3",
    "@tiptap/starter-kit": "^2.10.3",
    "dompurify": "^3.2.3",
    "markdown-it": "^14.1.0",
    "tiptap-markdown": "^0.8.10"
  },
  "devDependencies": {
    "esbuild": "^0.24.2"
  }
}
