# Copy to .env and fill in.
# A GitHub Personal Access Token (classic) with `repo` scope,
# or a fine-grained token with Contents + Issues read/write on the target repo.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# The repo that holds your wiki's Markdown files.
GITHUB_OWNER=your-org-or-user
GITHUB_REPO=your-wiki-repo

# The branch treated as "published"/main.
BASE_BRANCH=main

# Port for the local server.
PORT=4000
